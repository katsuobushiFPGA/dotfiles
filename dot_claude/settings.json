{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git commit:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run test:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo rm:*)",
      "Bash(rm --recursive:*)",
      "Bash(rm --force:*)",
      "Bash(rm -f:*)",
      "Bash(rm -R:*)",
      "Bash(find * -delete:*)",
      "Bash(find * -exec rm:*)",
      "Bash(xargs rm:*)",
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git config *)",
      "Bash(chmod 777 *)",
      "Read(.env*)",
      "Read(id_rsa*)",
      "Read(*.key)",
      "Read(*.pem)",
      "Write(.env*)",
      "Write(id_rsa*)",
      "Write(*.key)",
      "Write(*.pem)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/mark-file-changed.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/difit-on-commit.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/doc-sync-check.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/difit-on-stop.sh",
            "statusMessage": "difit で差分を表示中..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); printf '\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m' \"$(whoami)\" \"$(hostname -s)\" \"$(echo \"$input\" | jq -r '.cwd')\""
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "language": "Japanese",
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "voiceEnabled": true
}
