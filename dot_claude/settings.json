{
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); printf '\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m' \"$(whoami)\" \"$(hostname -s)\" \"$(echo \"$input\" | jq -r '.cwd')\""
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/mark-file-changed.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/difit-on-stop.sh",
            "statusMessage": "difit で差分を表示中..."
          }
        ]
      }
    ]
  }
}
