[tools]
node = "lts"
go = "1.22"
ripgrep = "latest"
fzf = "latest"
bat = "latest"
eza = "latest"
jq = "latest"
shellcheck = "latest"
zoxide = "latest"
gh = "latest"
ghq = "latest"
lazygit = "latest"
"go:github.com/k1LoW/git-wt" = "latest"
"npm:ccusage" = "latest"
"npm:tree-sitter-cli" = "latest"
"npm:agent-browser" = "latest"
"npm:@redwoodjs/agent-ci" = "latest"
"npm:difit" = "latest"
tmux = "latest"
{{ if eq .chezmoi.os "linux" -}}
fd = "latest"
delta = "latest"
{{ end -}}

[tasks.init]
description = "初回セットアップ（bootstrap.sh を実行）"
run = "bash ~/dotfiles/bootstrap.sh"

[tasks.check]
description = "dotfiles の静的チェック"
run = "bash ~/dotfiles/scripts/check"

[tasks.update]
description = "dotfiles・ツール一括アップデート"
run = "bash ~/dotfiles/scripts/update"
