[tools]
node = "lts"
go = "1.22"
ripgrep = "latest"
fzf = "latest"
bat = "latest"
eza = "latest"
zoxide = "latest"
gh = "latest"
ghq = "latest"
lazygit = "latest"
"npm:ccusage" = "latest"
"npm:tree-sitter-cli" = "latest"
"npm:agent-browser" = "latest"
"npm:@redwoodjs/agent-ci" = "latest"
"npm:difit" = "latest"
tmux = "latest"
{{ if eq .chezmoi.os "linux" -}}
fd = "latest"
delta = "latest"
{{ end -}}

[tasks.init]
description = "初回セットアップ（bootstrap.sh を実行）"
run = "bash ~/dotfiles/bootstrap.sh"

[tasks.update]
description = "dotfiles・ツール一括アップデート"
run = """
git -C ~/dotfiles pull --ff-only
chezmoi apply
mise upgrade
(cd ~ && npx -y skills experimental_install)
npx playwright install chromium
"""
