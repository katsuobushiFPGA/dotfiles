[tools]
node = "lts"
go = "1.22"
ripgrep = "latest"
fzf = "latest"
bat = "latest"
eza = "latest"
jq = "latest"
shellcheck = "latest"
zoxide = "latest"
gh = "latest"
ghq = "latest"
lazygit = "latest"
"go:github.com/k1LoW/git-wt" = "latest"
"npm:ccusage" = "latest"
"npm:tree-sitter-cli" = "latest"
"npm:agent-browser" = "latest"
"npm:@redwoodjs/agent-ci" = "latest"
"npm:difit" = "latest"
tmux = "latest"
{{ if eq .chezmoi.os "linux" -}}
fd = "latest"
delta = "latest"
{{ end -}}

[tasks.init]
description = "初回セットアップ（bootstrap.sh を実行）"
run = "bash ~/dotfiles/bootstrap.sh"

[tasks.check]
description = "dotfiles の静的チェック"
run = """
git diff --check
bash -n bootstrap.sh bin/claude-notify dot_claude/hooks/session-lib.sh dot_claude/hooks/executable_*.sh
jq empty dot_claude/settings.json dot_agents/dot_skill-lock.json
chezmoi apply --dry-run --source ~/dotfiles
shellcheck bootstrap.sh bin/claude-notify dot_claude/hooks/session-lib.sh dot_claude/hooks/executable_*.sh
"""

[tasks.update]
description = "dotfiles・ツール一括アップデート"
run = """
git -C ~/dotfiles pull --ff-only
chezmoi apply
mise upgrade
(cd ~ && npx -y skills experimental_install)
_APM_BIN=""
if [ -x "$HOME/.local/bin/apm" ]; then
  _APM_BIN="$HOME/.local/bin/apm"
elif command -v apm >/dev/null 2>&1; then
  _APM_BIN="$(command -v apm)"
fi
if [ -f "$HOME/.apm/apm.yml" ] && [ -n "$_APM_BIN" ]; then
  (cd "$HOME" && "$_APM_BIN" install -g)
fi
npx playwright install chromium
"""
