[user]
	email = {{ .email }}
	name = kbushi

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true

[diff]
	algorithm = histogram
	colorMoved = default

[rerere]
	enabled = true

[ghq]
	root = ~/workspace

[alias]
	co = checkout
	st = status
	br = branch
	lg = log --oneline --graph --decorate

[credential]
	helper = cache

[credential "https://github.com"]
	helper =
	helper = !{{ .chezmoi.homeDir }}/.local/share/mise/shims/gh auth git-credential

[credential "https://gist.github.com"]
	helper =
	helper = !{{ .chezmoi.homeDir }}/.local/share/mise/shims/gh auth git-credential
