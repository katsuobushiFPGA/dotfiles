#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_DIR"

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

find_apm_bin() {
  if [[ -x "$HOME/.local/bin/apm" ]]; then
    echo "$HOME/.local/bin/apm"
  elif command_exists apm; then
    command -v apm
  fi
}

if [[ "${DOTFILES_UPDATE_REEXECED:-}" != "1" ]]; then
  BEFORE_HEAD="$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null || true)"
  git -C "$REPO_DIR" pull --ff-only
  AFTER_HEAD="$(git -C "$REPO_DIR" rev-parse HEAD 2>/dev/null || true)"

  if [[ -n "$BEFORE_HEAD" && "$BEFORE_HEAD" != "$AFTER_HEAD" ]]; then
    export DOTFILES_UPDATE_REEXECED=1
    exec bash "$REPO_DIR/scripts/update"
  fi
fi

chezmoi apply --source "$REPO_DIR"
mise upgrade

if command_exists npx && [[ -f "$HOME/.agents/.skill-lock.json" ]]; then
  (cd "$HOME" && npx -y skills experimental_install)
fi

APM_BIN="$(find_apm_bin || true)"
if [[ -f "$HOME/.apm/apm.yml" && -n "$APM_BIN" ]]; then
  (cd "$HOME" && "$APM_BIN" install -g)
  # apm install -g は現状 generated_at を書き戻さないが、apm の将来バージョン変化に備えて除去
  if [[ -f "$HOME/.apm/apm.lock.yaml" ]]; then
    sed -i.bak '/^generated_at:/d' "$HOME/.apm/apm.lock.yaml"
    rm -f "$HOME/.apm/apm.lock.yaml.bak"
  fi
fi

if command_exists uv; then
  # serena が未インストールの場合 uv は exit 1 になり得る（uv のバージョン依存）。
  # set -Eeuo pipefail 配下で update を止めないよう || true で握る。初回 install は bootstrap.sh が担当。
  uv tool upgrade serena-agent --prerelease=allow || true
fi

if command_exists npx; then
  npx playwright install chromium
fi
